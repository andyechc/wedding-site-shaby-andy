---
const weddingDate = '2026-04-25T00:00:00';
---

<section class="py-20 px-6 bg-[#F5F0EB]" data-animate="fade-up">
  <div class="max-w-3xl mx-auto text-center">
    <div class="gold-divider-thick w-16 mx-auto mb-10" />

    <h2 class="font-serif text-2xl md:text-3xl text-dark-text font-light tracking-wide mb-14">
      <span class="highlight-marker">Time Since Our Wedding</span>
    </h2>

    <div class="flex justify-center items-start gap-8 md:gap-16">
      <div class="flex flex-col items-center min-w-[80px]">
        <span class="counter-value font-serif text-4xl md:text-5xl text-gold font-bold tabular-nums leading-none" data-target="years">0</span>
        <span class="font-sans text-[10px] tracking-[0.2em] uppercase text-dark-muted mt-3">Years</span>
      </div>
      <div class="flex flex-col items-center min-w-[80px]">
        <span class="counter-value font-serif text-4xl md:text-5xl text-gold font-bold tabular-nums leading-none" data-target="months">0</span>
        <span class="font-sans text-[10px] tracking-[0.2em] uppercase text-dark-muted mt-3">Months</span>
      </div>
      <div class="flex flex-col items-center min-w-[80px]">
        <span class="counter-value font-serif text-4xl md:text-5xl text-gold font-bold tabular-nums leading-none" data-target="days">0</span>
        <span class="font-sans text-[10px] tracking-[0.2em] uppercase text-dark-muted mt-3">Days</span>
      </div>
      <div class="flex flex-col items-center min-w-[80px]">
        <span class="counter-value font-serif text-4xl md:text-5xl text-gold font-bold tabular-nums leading-none" data-target="hours">0</span>
        <span class="font-sans text-[10px] tracking-[0.2em] uppercase text-dark-muted mt-3">Hours</span>
      </div>
      <div class="flex flex-col items-center min-w-[80px]">
        <span class="counter-value font-serif text-4xl md:text-5xl text-gold font-bold tabular-nums leading-none" data-target="minutes">0</span>
        <span class="font-sans text-[10px] tracking-[0.2em] uppercase text-dark-muted mt-3">Minutes</span>
      </div>
    </div>

    <div class="gold-divider-thick w-16 mx-auto mt-14" />
  </div>
</section>

<script>
  const wedding = new Date('2026-04-25T00:00:00');

  function computeDiff() {
    const now = new Date();
    const diffMs = now - wedding;
    const totalSeconds = Math.floor(diffMs / 1000);
    const years = now.getFullYear() - wedding.getFullYear();
    const months = (now.getFullYear() - wedding.getFullYear()) * 12 + (now.getMonth() - wedding.getMonth());
    const days = Math.floor(totalSeconds / 86400);
    const hours = Math.floor((totalSeconds % 86400) / 3600);
    const minutes = Math.floor((totalSeconds % 3600) / 60);
    return { years, months, days, hours, minutes };
  }

  function animateValue(el, target) {
    let current = 0;
    const step = Math.max(1, Math.ceil(target / 30));
    const interval = setInterval(() => {
      current += step;
      if (current >= target) {
        current = target;
        clearInterval(interval);
      }
      el.textContent = current;
    }, 50);
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const diff = computeDiff();
          document.querySelectorAll('.counter-value').forEach((el) => {
            const key = el.dataset.target;
            animateValue(el, diff[key]);
          });
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.3 }
  );

  const section = document.querySelector('.counter-value')?.closest('section');
  if (section) observer.observe(section);
</script>
