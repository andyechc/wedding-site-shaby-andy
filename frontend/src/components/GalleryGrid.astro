---
import { getBentoSpan, bentoClassFromRatio } from '../utils/images';

const { photos, tabId } = Astro.props;
const initialCount = 24;
const allPhotosJson = JSON.stringify(photos.map((p, i) => ({
  ...p,
  bentoClass: getBentoSpan(p.id, i),
})));
const initialPhotos = photos.slice(0, initialCount);
const initialBento = initialPhotos.map((p, i) => getBentoSpan(p.id, i));
---

<div id={`grid-${tabId}`} class="gallery-grid" data-animate="fade-up" data-tab-id={tabId} data-photos={allPhotosJson} data-count={initialCount}>
  <div id={`grid-inner-${tabId}`} class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 auto-rows-[180px] md:auto-rows-[220px]">
    {initialPhotos.map((photo, i) => (
      <div
        class={`photo-frame cursor-pointer overflow-hidden ${initialBento[i] || ''}`}
        data-animate="fade-up"
        style={`animation-delay: ${(i % 12) * 80}ms`}
        data-protected
      >
        <img
          src={`https://shaby-and-andy-wedding.andyechc.workers.dev/media/${photo.id}`}
          alt={photo.title || 'Wedding photo'}
          class="w-full h-full object-cover"
          draggable="false"
          loading="lazy"
          decoding="async"
          fetchpriority={i < 6 ? 'high' : 'low'}
          data-gallery-id={tabId}
          data-index={i}
        />
      </div>
    ))}
  </div>
  <div id={`sentinel-${tabId}`} class="h-4" />
</div>

<script>
  function mediaIdFromSrc(src) {
    const path = new URL(src).pathname;
    const parts = path.split('/media/');
    return parts.length > 1 ? parts[1] : path;
  }

  function bentoClassFromRatio(w, h) {
    if (!w || !h) return '';
    const ratio = w / h;
    if (ratio > 1.3) return 'col-span-2';
    if (ratio < 0.77) return 'row-span-2';
    return '';
  }

  function applyBentoOnLoad(img, frame) {
    if (img.complete && img.naturalWidth) {
      const cls = bentoClassFromRatio(img.naturalWidth, img.naturalHeight);
      if (cls) frame.classList.add(cls);
    } else {
      img.addEventListener('load', () => {
        const cls = bentoClassFromRatio(img.naturalWidth, img.naturalHeight);
        if (cls) frame.classList.add(cls);
      });
    }
  }

  document.querySelectorAll('[data-tab-id]').forEach((grid) => {
    const tabId = grid.dataset.tabId;
    const allPhotos = JSON.parse(grid.dataset.photos);
    let loadedCount = Number(grid.dataset.count);
    const gridInner = document.getElementById(`grid-inner-${tabId}`);
    const sentinel = document.getElementById(`sentinel-${tabId}`);

    // Apply bento to initial photos based on actual ratios
    gridInner.querySelectorAll('.photo-frame').forEach((frame) => {
      const img = frame.querySelector('img');
      if (img) applyBentoOnLoad(img, frame);
    });

    function attachClick() {
      gridInner.querySelectorAll('.photo-frame').forEach((frame) => {
        frame.addEventListener('click', () => {
          const allFrames = gridInner.querySelectorAll('.photo-frame');
          const items = [...allFrames].map((el) => {
            const i = el.querySelector('img');
            return { id: mediaIdFromSrc(i.src), title: i.alt };
          });
          const img = frame.querySelector('img');
          const index = Number(img.dataset.index);
          window.openLightbox(index, items);
        });
      });
    }

    attachClick();

    if (sentinel && allPhotos.length > loadedCount) {
      const observer = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting) {
          const batch = allPhotos.slice(loadedCount, loadedCount + 24);
          batch.forEach((photo, i) => {
            const idx = loadedCount + i;
            const div = document.createElement('div');
            div.className = 'photo-frame cursor-pointer overflow-hidden';
            div.setAttribute('data-protected', '');
            div.setAttribute('data-animate', 'fade-up');
            div.style.animationDelay = `${(idx % 12) * 80}ms`;

            const img = document.createElement('img');
            img.src = `https://shaby-and-andy-wedding.andyechc.workers.dev/media/${photo.id}`;
            img.alt = photo.title || 'Wedding photo';
            img.className = 'w-full h-full object-cover';
            img.draggable = false;
            img.loading = 'lazy';
            img.decoding = 'async';
            img.fetchPriority = 'low';
            img.dataset.galleryId = tabId;
            img.dataset.index = idx;

            div.addEventListener('click', () => {
              const allFrames = gridInner.querySelectorAll('.photo-frame');
              const items = [...allFrames].map((el) => {
                const i = el.querySelector('img');
                return { id: mediaIdFromSrc(i.src), title: i.alt };
              });
              const index = Number(img.dataset.index);
              window.openLightbox(index, items);
            });
            div.appendChild(img);
            gridInner.appendChild(div);
            div.classList.add('is-visible');
            applyBentoOnLoad(img, div);
          });
          loadedCount += batch.length;
          if (loadedCount >= allPhotos.length) observer.unobserve(sentinel);
        }
      }, { rootMargin: '200px' });
      observer.observe(sentinel);
    }
  });
</script>
