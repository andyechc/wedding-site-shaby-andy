---
const { photoIds } = Astro.props;
const firstImage = photoIds[0];
const photosJson = JSON.stringify(photoIds);
---

<section class="relative h-screen w-full overflow-hidden hero-section" data-protected data-photos={photosJson}>
  <div id="hero-a" class="hero-layer absolute inset-0 bg-cover bg-center" style={`background-image: url(${firstImage.startsWith('website-images/') ? '/' + firstImage : '/media/' + firstImage}); opacity: 0; z-index: 10;`} />
  <div id="hero-b" class="hero-layer absolute inset-0 bg-cover bg-center" style="opacity: 0; z-index: 9;" />

  <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.20) 30%, rgba(0,0,0,0.15) 60%, rgba(0,0,0,0.55) 100%); z-index: 20;" />

  <div class="absolute inset-0 z-30 flex flex-col items-center justify-center px-6 pb-12 md:pb-16">
    <p class="font-sans text-xs md:text-sm tracking-[0.3em] uppercase text-white/90 mb-4 md:mb-6" data-animate="fade-in">
      April 25, 2026
    </p>
    <h1 class="font-script text-4xl sm:text-6xl md:text-7xl lg:text-8xl gold-text text-center leading-tight py-4 px-2" data-animate="fade-up">
      Shabelly & Jose A.
    </h1>
    <div class="gold-divider w-20 md:w-24 mt-6 md:mt-8 mb-4 md:mb-6 opacity-80" data-animate="fade-in" />
    <p class="font-body text-lg md:text-xl text-white/80 text-center font-light tracking-wide" data-animate="fade-up" style="animation-delay: 200ms;">
      Thank you for celebrating with us
    </p>
  </div>

  <div class="absolute bottom-6 md:bottom-10 left-0 right-0 z-30 flex flex-col items-center gap-2 text-white/40 animate-bounce-subtle">
    <span class="font-sans text-[10px] tracking-[0.15em] uppercase text-center">Scroll</span>
    <svg width="16" height="24" viewBox="0 0 16 24" fill="none" class="text-white/30">
      <path d="M8 0v20M8 20l-6-6M8 20l6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
</section>

<script>
  const section = document.querySelector('.hero-section');
  const a = document.getElementById('hero-a');
  const b = document.getElementById('hero-b');

  if (section && a && b) {
  const ids = JSON.parse(section.dataset.photos);
    [a, b].forEach(el => el.style.transition = 'opacity 1s ease-in-out');

    function mediaUrl(id) {
      if (id && id.startsWith('website-images/')) return `/${id}`;
      return `https://boda-media-proxy.andyechc.workers.dev/media/${id}`;
    }

    function preload(url, onDone) {
      const img = new Image();
      img.onload = onDone;
      img.onerror = onDone;
      img.src = url;
    }

    if (ids.length > 0) {
      const firstUrl = a.style.backgroundImage.match(/url\(['\"]?(.*?)['\"]?\)/i)?.[1];
      if (firstUrl) preload(firstUrl, () => { a.style.opacity = '1'; });
      else a.style.opacity = '1';
    }

    if (ids.length > 1) {
      let active = a;
      let inactive = b;
      let currentId = ids[0];

      setInterval(() => {
        let nextId;
        do {
          nextId = ids[Math.floor(Math.random() * ids.length)];
        } while (nextId === currentId && ids.length > 1);
        currentId = nextId;

        const url = mediaUrl(nextId);
        preload(url, () => {
          inactive.style.backgroundImage = `url(${url})`;
          inactive.style.opacity = '1';
          active.style.opacity = '0';
          [active, inactive] = [inactive, active];
        });
      }, 5000);
    }
  }
</script>
