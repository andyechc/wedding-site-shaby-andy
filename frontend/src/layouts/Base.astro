---
import '../styles/base.css';
const site = 'https://shaby-and-andy-wedding.vercel.app';
const path = Astro.url.pathname;
const isHome = path === '/' || path === '';
const isGallery = path.startsWith('/gallery');
const ogImage = `${site}/og-image.png`;
const pageTitle = isHome ? 'Shabelly & Jose A.' : isGallery ? 'Gallery — Shabelly & Jose A.' : 'Shabelly & Jose A.';
const description = 'April 25, 2026 — Thank you for celebrating with us';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FAF8F5" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>

    <meta property="og:type" content="website" />
    <meta property="og:url" content={site + path} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="800" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <nav id="main-nav" class="nav-base fixed top-0 left-0 right-0 z-50 transition-all duration-500" style="padding-top: max(1rem, env(safe-area-inset-top)); padding-bottom: 1rem;">
      <div class="flex items-center justify-between mx-auto" style="max-width: 1000px; padding-left: 1.5rem; padding-right: 1.5rem;">
        <a href="/" class="font-script text-2xl gold-text leading-none">S & A</a>
        <div class="flex items-center gap-4 sm:gap-8 text-xs sm:text-sm font-sans tracking-widest uppercase">
          <a href="/" class="nav-link" class:list={{ 'nav-link-active': isHome }}>Home</a>
          <a href="/gallery" class="nav-link" class:list={{ 'nav-link-active': isGallery }}>Gallery</a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <slot name="footer" />

    <button id="scroll-top" class="fixed z-40 w-12 h-12 flex items-center justify-center rounded-full bg-gold/90 hover:bg-gold text-white shadow-lg transition-all duration-300 opacity-0 translate-y-4 pointer-events-none" style="bottom: max(2rem, calc(2rem + env(safe-area-inset-bottom))); right: 2rem;" aria-label="Scroll to top">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 15l-6-6-6 6"/></svg>
    </button>

    <script>
      import { ContentProtector } from '@tindalabs/shield';

      document.addEventListener('DOMContentLoaded', () => {
        const isMobile = /Android|iPhone|iPad|iPod|webOS|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent) || ('ontouchstart' in window) || window.innerWidth < 768;

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
              } else {
                entry.target.classList.remove('is-visible');
              }
            });
          },
          { threshold: 0.01, rootMargin: isMobile ? '0px 0px 100px 0px' : '0px 0px -40px 0px' }
        );
        document.querySelectorAll('[data-animate]').forEach((el) => observer.observe(el));

        document.querySelectorAll('img:not([data-no-blur])').forEach((img) => {
          if (img.complete) {
            img.classList.add('loaded');
          } else {
            img.classList.add('blur-load');
            img.addEventListener('load', () => {
              img.classList.remove('blur-load');
              img.classList.add('loaded');
            });
          }
        });

        const nav = document.getElementById('main-nav');
        if (nav) {
          const onScroll = () => {
            if (window.scrollY > 60) {
              nav.classList.add('nav-glass');
              nav.classList.remove('nav-transparent');
            } else {
              nav.classList.remove('nav-glass');
              nav.classList.add('nav-transparent');
            }
          };
          onScroll();
          window.addEventListener('scroll', onScroll, { passive: true });
        }

        const scrollBtn = document.getElementById('scroll-top');
        if (scrollBtn) {
          const toggleScrollBtn = () => {
            if (window.scrollY > 500) {
              scrollBtn.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
              scrollBtn.classList.add('opacity-100', 'translate-y-0');
            } else {
              scrollBtn.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
              scrollBtn.classList.remove('opacity-100', 'translate-y-0');
            }
          };
          window.addEventListener('scroll', toggleScrollBtn, { passive: true });
          scrollBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
        }

        const protector = new ContentProtector({
          preventContextMenu: !isMobile,
          preventKeyboardShortcuts: true,
          preventPrinting: true,
          preventSelection: !isMobile,
          preventScreenshots: true,
          preventDevTools: true,
          preventClipboard: true,
        });
        protector.protect();

        let visibleAt = Date.now();
        let screenshotAlertTimeout = null;

        document.addEventListener('visibilitychange', () => {
          if (document.visibilityState === 'visible') {
            const elapsed = Date.now() - visibleAt;
            visibleAt = Date.now();
            if (elapsed < 1500 && !screenshotAlertTimeout) {
              screenshotAlertTimeout = setTimeout(() => { screenshotAlertTimeout = null; }, 3000);
              showScreenshotAlert();
            }
          } else {
            visibleAt = Date.now();
          }
        });

        window.addEventListener('pageshow', (e) => {
          if (e.persisted && !screenshotAlertTimeout) {
            screenshotAlertTimeout = setTimeout(() => { screenshotAlertTimeout = null; }, 3000);
            showScreenshotAlert();
          }
        });

        function showScreenshotAlert() {
          const existing = document.getElementById('screenshot-alert');
          if (existing) return;
          const alert = document.createElement('div');
          alert.id = 'screenshot-alert';
          alert.style.cssText = 'position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.85);display:flex;flex-direction:column;align-items:center;justify-content:center;animation:fadeIn .3s ease;';
          alert.innerHTML = '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="1.5" stroke-linecap="round"><path d="M12 9v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><p style="color:#fff;font-family:serif;font-size:1.1rem;margin-top:1rem;text-align:center;padding:0 2rem;">This content is protected.<br>Screenshots are not allowed.</p>';
          document.body.appendChild(alert);
          setTimeout(() => { alert.style.opacity = '0'; alert.style.transition = 'opacity .5s ease'; }, 2500);
          setTimeout(() => { alert.remove(); }, 3000);
        }
      });
    </script>
  </body>
</html>
